NODE_ENV=development
PORT=5000

# Supabase PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/neargrab?schema=public


# Authentication
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

#Cors Origin
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Media Upload (Cloudinary or Local)
# Add your Cloudinary API environment variable here (e.g. cloudinary://API_KEY:API_SECRET@CLOUD_NAME)
CLOUDINARY_URL=

# Media Upload Configuration
# Set to 'cloudinary' or 'local'
UPLOAD_DRIVER=local
UPLOAD_DIR=uploads
UPLOAD_MAX_FILE_SIZE_BYTES=5242880

# Rate Limiter
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Information
LOG_LEVEL=info

#
PUBLIC_BASE_URL=http://localhost:5000

# Google Auth
GOOGLE_CLIENT_ID=

# Email and SMS Service
SMS_PROVIDER=mock
EMAIL_PROVIDER=mock
